NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://user:password@host:5432/air_quality
REQUEST_BODY_LIMIT_BYTES=4096
IP_RATE_LIMIT_MAX=120
IP_RATE_LIMIT_WINDOW_MS=60000
DEVICE_RATE_LIMIT_MAX=10
DEVICE_RATE_LIMIT_WINDOW_MS=60000
DEVICE_REQUEST_MAX_SKEW_MS=300000
DEVICE_RETRY_AFTER_SECONDS=60
DEVICE_SECRET_ENCRYPTION_KEY=replace-with-64-char-hex-key
FORWARDER_INTERVAL_MS=600000
FORWARDER_BATCH_SIZE=100
FORWARDER_MAX_RETRIES=12
FORWARDER_STALE_PROCESSING_MS=900000
FORWARDER_MAX_CONFLICTS_BEFORE_DEAD_LETTER=3
CONVEX_URL=https://your-deployment.convex.site
CONVEX_INGEST_PATH=/api/v1/readings/batch
CONVEX_HMAC_SECRET=replace-with-server-to-server-secret
CONVEX_CREDENTIAL_VERSION=1
CONVEX_MAX_SKEW_MS=300000
CRON_SECRET=replace-with-long-random-cron-secret
